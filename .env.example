# Supabase Auth — copy this file to `.env.local` and fill in your project values.
# When BOTH are set, the app uses real Supabase auth (login, forgot/reset password,
# email verification, session persistence). When either is missing, it transparently
# falls back to the mock/localStorage auth + demo accounts.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
